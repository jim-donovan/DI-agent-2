# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional (only used for evaluation comparison)
OPENAI_API_KEY=sk-proj-...

# Agent toggles
ENABLE_CONTENT_FORMATTING_AGENT=true
ENABLE_SUMMARY_AGENT=false

# Processing
USE_PARALLEL_VISION=true
USE_LOCAL_DOWNLOADS_DIRECTORY=true
DEBUG_OCR_PIPELINE=false

# UI Feature Toggles
ENABLE_SUMMARY_GENERATION=false
ENABLE_QUALITY_REPORT=false
ENABLE_RAW_OCR_OUTPUT=false

# Optional: Tally form ID for feedback collection
# TALLY_FORM_ID=
